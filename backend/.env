FIREWORKS_API_KEY="Enter your API KEY here"

# MAIN provider: GENUINE on-GPU AMD compute (Gemma 4 26B via Ollama).
# Ollama runs inside the `rocm` Docker container on the AMD Cloud GPU
# droplet (container IP 172.17.0.2, port 11434 - not published to the host,
# so it's not reachable by curling the droplet's public IP directly).
# Reached from this machine via an SSH local port-forward run on THIS PC:
#   ssh -i C:\Users\matth\.ssh\amd_droplet_key -N -L 11434:172.17.0.2:11434 root@165.245.136.23
# That tunnel must stay running (its own terminal window, left open) any
# time this provider needs to be reachable - see HANDOFF.md. If no tunnel
# is running, this provider fails its connectivity check and silently
# falls through to Fireworks.
AMD_OLLAMA_URL=http://localhost:11434/v1/chat/completions
AMD_OLLAMA_MODEL=gemma4:26b

# FALLBACK provider, used if AMD isn't reachable: fastest Fireworks
# serverless, GLM 5.2 (DIRECT, pay-per-token)
FIREWORKS_FAST_SERVERLESS_MODEL=accounts/fireworks/models/glm-5p2
