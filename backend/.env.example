# ==============================================================================
# Backend Environment Variables
# ==============================================================================

# ─── Fireworks AI Credits ────────────────────────────────────────────────
# REQUIRED for the fallback provider.
FIREWORKS_API_KEY=""

# FALLBACK provider, used if AMD isn't reachable. GLM 5.2.
FIREWORKS_FAST_SERVERLESS_MODEL="accounts/fireworks/models/glm-5p2"

# ─── AMD Developer Cloud (Ollama — GENUINE on-GPU compute, MI300X/ROCm) ─────
# MAIN provider. Gemma 4 26B (MoE) running locally via Ollama, hit directly.
# Default for local development via SSH tunnel:
AMD_OLLAMA_URL="http://localhost:11434/v1/chat/completions"
# Use this when running on the droplet itself:
# AMD_OLLAMA_URL="http://172.17.0.2:11434/v1/chat/completions"

AMD_OLLAMA_MODEL="gemma4:26b"

# ==============================================================================
# General
# ==============================================================================
LOG_LEVEL="info"
