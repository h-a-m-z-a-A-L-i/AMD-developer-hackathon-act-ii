# ─── Fireworks AI Credits ────────────────────────────────────────────────
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ─── Featherless AI (used for testing, switching to a Gemma model before submission) ──
FEATHERLESS_API_KEY=
FEATHERLESS_MODEL=google/gemma-2-9b-it

# ─── AMD Developer Cloud (Synthesis Notebook Runner) ────────────────────
AMD_CLOUD_ENDPOINT=
AMD_CLOUD_API_KEY=
AMD_NOTEBOOK_ID=

# ─── Backend Gateway ──────────────────────────────────────────────────────
BACKEND_BASE_URL=http://localhost:8000

# ─── General ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

